# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#

# ─────────────────────────────────────────────────────────────────────────────
# Ignore global Unity cache folders (for the sub‑project folder)
# ─────────────────────────────────────────────────────────────────────────────

/CYBER_SPONGE_CATS_TAKE_2/[Ll]ibrary/
/CYBER_SPONGE_CATS_TAKE_2/[Tt]emp/
/CYBER_SPONGE_CATS_TAKE_2/[Oo]bj/
/CYBER_SPONGE_CATS_TAKE_2/[Bb]uild/
/CYBER_SPONGE_CATS_TAKE_2/[Bb]uilds/
/CYBER_SPONGE_CATS_TAKE_2/[Ll]ogs/
/CYBER_SPONGE_CATS_TAKE_2/[Uu]ser[Ss]ettings/
/CYBER_SPONGE_CATS_TAKE_2/[Mm]emoryCaptures/
/CYBER_SPONGE_CATS_TAKE_2/[Rr]ecordings/

# ─────────────────────────────────────────────────────────────────────────────
# Unity-generated (any project)
# ─────────────────────────────────────────────────────────────────────────────

.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

/[Mm]emoryCaptures/
/[Rr]ecordings/

# Uncomment to ignore the Asset Store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache
.vs/

# Gradle cache
.gradle/

# Auto-generated VS/MD/Consulo files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Android streaming assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
